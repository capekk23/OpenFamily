# Database
DATABASE_URL="postgresql://openfamily:openfamily@localhost:5432/openfamily"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="change-me-in-production"
JWT_REFRESH_SECRET="change-me-refresh-in-production"

# Encryption key for stored API keys (32+ chars, keep secret)
SETTINGS_ENCRYPTION_KEY="change-me-to-a-random-32-char-string"

# Anthropic (used as default supervisor provider if no DB config)
ANTHROPIC_API_KEY="sk-ant-..."

# Optional: OpenRouter (alternative supervisor provider)
# OPENROUTER_API_KEY="sk-or-..."

# Logging
LOG_LEVEL="info"  # trace | debug | info | warn | error

# Service ports
GATEWAY_PORT=3001
API_PORT=3002
SUPERVISOR_PORT=3003
DASHBOARD_PORT=3000

# Internal service URLs
GATEWAY_URL="http://localhost:3001"
API_URL="http://localhost:3002"
SUPERVISOR_URL="http://localhost:3003"
