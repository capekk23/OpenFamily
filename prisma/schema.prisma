generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Policy {
  id        String   @id @default(cuid())
  name      String
  version   Int      @default(1)
  isActive  Boolean  @default(true)
  rules     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions AgentSession[]
  events   ActionEvent[]
  apiKeys  ApiKey[]
}

model AgentSession {
  id          String        @id @default(cuid())
  agentId     String
  agentName   String?
  policyId    String
  policy      Policy        @relation(fields: [policyId], references: [id])
  apiKeyHash  String
  status      SessionStatus @default(ACTIVE)
  spentBudget Decimal       @default(0) @db.Decimal(12, 6)
  startedAt   DateTime      @default(now())
  endedAt     DateTime?

  events    ActionEvent[]
  approvals ApprovalRequest[]
}

model ActionEvent {
  id              String   @id @default(cuid())
  sessionId       String
  policyId        String
  toolName        String
  toolInput       Json
  toolOutput      Json?
  decision        Decision
  reason          String?
  estimatedCost   Decimal? @db.Decimal(12, 6)
  supervisorUsed  Boolean  @default(false)
  supervisorNotes String?
  timestamp       DateTime @default(now())

  session  AgentSession     @relation(fields: [sessionId], references: [id])
  policy   Policy           @relation(fields: [policyId], references: [id])
  approval ApprovalRequest?
}

model ApprovalRequest {
  id          String         @id @default(cuid())
  eventId     String         @unique
  sessionId   String
  status      ApprovalStatus @default(PENDING)
  requestedAt DateTime       @default(now())
  expiresAt   DateTime
  resolvedBy  String?
  reviewNote  String?

  event   ActionEvent  @relation(fields: [eventId], references: [id])
  session AgentSession @relation(fields: [sessionId], references: [id])

  @@index([status, expiresAt])
}

model ApiKey {
  id         String    @id @default(cuid())
  keyHash    String    @unique
  name       String
  policyId   String
  policy     Policy    @relation(fields: [policyId], references: [id])
  isActive   Boolean   @default(true)
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         UserRole @default(REVIEWER)
  createdAt    DateTime @default(now())
}

enum SessionStatus {
  ACTIVE
  TERMINATED
  EXPIRED
}

enum Decision {
  APPROVED
  BLOCKED
  APPROVED_BY_SUPERVISOR
  DENIED_BY_SUPERVISOR
  PENDING_HUMAN
  APPROVED_BY_HUMAN
  DENIED_BY_HUMAN
  TIMED_OUT
}

enum ApprovalStatus {
  PENDING
  APPROVED
  DENIED
  TIMED_OUT
}

enum UserRole {
  ADMIN
  REVIEWER
  READONLY
}
